# SharePay environment (copy to .env and customize)
# Used by docker-compose and local dev

# Database (postgres service in compose)
DB_HOST=db
DB_PORT=5432
DB_USER=sharepay
DB_PASSWORD=change_this_in_production_please_use_strong
DB_NAME=sharepay

# Auth
JWT_SECRET=replace_with_long_random_secret_at_least_32_chars_in_prod

# App
NODE_ENV=production
PORT=3000

# Optional: API base for web if reverse proxy differs
# API_URL=http://localhost:3000
