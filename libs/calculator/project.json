{
  "name": "calculator",
  "sourceRoot": "libs/calculator/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/calculator",
        "main": "libs/calculator/src/index.ts",
        "tsConfig": "libs/calculator/tsconfig.lib.json",
        "assets": []
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/calculator/jest.config.ts",
        "passWithNoTests": false
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/calculator/tsconfig.lib.json --noEmit"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/calculator/**/*.ts"]
      }
    }
  },
  "tags": ["scope:domain", "type:util"]
}
