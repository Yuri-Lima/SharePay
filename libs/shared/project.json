{
  "name": "shared",
  "sourceRoot": "libs/shared/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "options": { "outputPath": "dist/libs/shared", "main": "libs/shared/src/index.ts", "tsConfig": "libs/shared/tsconfig.lib.json" }
    },
    "test": { "executor": "@nx/jest:jest", "options": { "jestConfig": "libs/shared/jest.config.ts", "passWithNoTests": true } },
    "typecheck": { "executor": "nx:run-commands", "options": { "command": "tsc -p libs/shared/tsconfig.lib.json --noEmit" } }
  },
  "tags": ["scope:shared", "type:util"]
}
