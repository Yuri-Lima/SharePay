{
  "name": "sharepay",
  "version": "2.0.0",
  "private": true,
  "description": "SharePay - Fair energy bill splitter for shared houses and sub-houses. Migrated to TypeScript Nx + pnpm + NestJS + Angular.",
  "author": "Yuri Lima",
  "license": "MIT",
  "scripts": {
    "nx": "nx",
    "build": "nx run-many -t build --parallel=3",
    "build:affected": "nx affected -t build",
    "test": "nx run-many -t test --parallel=3 --passWithNoTests",
    "test:affected": "nx affected -t test",
    "lint": "nx run-many -t lint --parallel=3",
    "lint:affected": "nx affected -t lint",
    "typecheck": "nx run-many -t typecheck --parallel=3",
    "e2e": "nx run web-e2e:e2e --headed=false",
    "e2e:ui": "nx run web-e2e:e2e --ui",
    "dev:api": "nx serve api",
    "dev:web": "nx serve web",
    "start": "pnpm dev:api & pnpm dev:web",
    "graph": "nx graph",
    "clean": "rm -rf dist tmp .nx node_modules/.cache",
    "prepare": "husky install || true",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build:api": "docker build -f docker/Dockerfile.api -t sharepay-api .",
    "docker:build:web": "docker build -f docker/Dockerfile.web -t sharepay-web .",
    "docker:ci:verify": "docker compose config && docker compose build --no-cache"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.2.21",
    "@angular/common": "^18.2.14",
    "@angular/compiler": "^18.2.14",
    "@angular/compiler-cli": "^18.2.14",
    "@angular/core": "^18.2.14",
    "@angular/forms": "^18.2.14",
    "@angular/platform-browser": "^18.2.14",
    "@angular/platform-browser-dynamic": "^18.2.14",
    "@angular/router": "^18.2.14",
    "@nestjs/testing": "^10.3.10",
    "@nx/angular": "19.8.4",
    "@nx/devkit": "19.8.4",
    "@nx/eslint": "19.8.4",
    "@nx/jest": "19.8.4",
    "@nx/js": "19.8.4",
    "@nx/node": "19.8.4",
    "@nx/playwright": "19.8.4",
    "@playwright/test": "^1.45.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "decimal.js": "^10.4.3",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "jest-environment-node": "^29.7.0",
    "jest-preset-angular": "^16.2.0",
    "nx": "19.8.4",
    "prettier": "^3.3.3",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.5.4",
    "zone.js": "~0.14.10"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.10",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.3.10",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.10",
    "@nestjs/throttler": "^6.0.0",
    "@nestjs/typeorm": "^10.0.2",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^3.6.0",
    "helmet": "^7.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sqlite3": "^5.1.7",
    "tslib": "^2.6.2",
    "typeorm": "^0.3.20"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.0",
  "nx": {
    "includedScripts": []
  }
}
